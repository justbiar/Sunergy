# Foundry deploy
PRIVATE_KEY=0x...                              # deployer key, must hold testnet MON
ADMIN_ADDRESS=0x...                            # admin/owner of the deployed contracts (defaults to deployer)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com/api
MONAD_EXPLORER_API_KEY=                        # optional, for verify

# Web app — paste here after deploy, then restart `npm run dev`
NEXT_PUBLIC_FARM_REGISTRY=
NEXT_PUBLIC_ORACLE=
NEXT_PUBLIC_REWARDS=
NEXT_PUBLIC_SUN_TOKEN=
NEXT_PUBLIC_CARBON=
NEXT_PUBLIC_WC_PROJECT_ID=                     # optional WalletConnect Cloud project id
